<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DatPlotX.Views.Controls.Dpx.AxisSideToggle">

    <UserControl.Styles>
        <Style Selector="ToggleButton.axis">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource DpxText3}"/>
        </Style>
        <Style Selector="ToggleButton.axis:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DpxSurface}"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource DpxText}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource DpxSunken}"
            BorderBrush="{StaticResource DpxBorder}"
            BorderThickness="1"
            CornerRadius="5"
            Padding="2"
            HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal">
            <ToggleButton x:Name="LeftBtn" Classes="axis" Content="L"/>
            <ToggleButton x:Name="RightBtn" Classes="axis" Content="R"/>
        </StackPanel>
    </Border>
</UserControl>
