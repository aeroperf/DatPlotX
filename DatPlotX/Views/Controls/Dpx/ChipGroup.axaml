<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DatPlotX.Views.Controls.Dpx.ChipGroup">

    <UserControl.Styles>
        <Style Selector="ToggleButton.gchip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource DpxText2}"/>
            <Setter Property="FontSize" Value="11.5"/>
        </Style>
        <Style Selector="ToggleButton.gchip:pointerover /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{StaticResource DpxText}"/>
        </Style>
        <Style Selector="ToggleButton.gchip:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DpxSurface}"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource DpxText}"/>
        </Style>
        <Style Selector="ToggleButton.gchip:checked">
            <Setter Property="BorderBrush" Value="{StaticResource DpxBorder}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource DpxSunken}"
            BorderBrush="{StaticResource DpxBorder}"
            BorderThickness="1"
            CornerRadius="7"
            Padding="3">
        <ItemsControl x:Name="ItemsHost">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Border>
</UserControl>
