<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DatPlotX.Views.ExportOrientationDialog"
        x:CompileBindings="True"
        Title="Export Orientation"
        Width="400" Height="220"
        Classes="dpx"
        Background="{StaticResource DpxBg}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="*,Auto">

        <StackPanel Grid.Row="0" Margin="20,16,20,14" Spacing="10">
            <TextBlock Classes="dpx-h1" Text="Export image"/>
            <TextBlock Classes="dpx-subtitle"
                       Text="Choose an orientation for the exported image."/>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Classes="dpx primary" Content="Landscape" MinWidth="120"
                        Click="Landscape_Click"/>
                <Button Classes="dpx" Content="Portrait" MinWidth="120"
                        Click="Portrait_Click"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Classes="dpx-footer">
            <Grid ColumnDefinitions="*,Auto">
                <Button Grid.Column="1" Classes="dpx ghost" Content="Cancel"
                        Click="Cancel_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
