<Window x:Class="DatPlotX.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DatPlotX.Views"
        xmlns:vm="clr-namespace:DatPlotX.ViewModels"
        xmlns:conv="clr-namespace:DatPlotX.Converters"
        xmlns:ac="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
        mc:Ignorable="d"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Title="{Binding WindowTitle}"
        Icon="/Assets/icon.png"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:BoolToGridLengthConverter x:Key="BoolToGridLength"/>
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveProjectAsCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportImageCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding ExportIntersectionsCommand}"/>
        <KeyBinding Gesture="Ctrl+Q" Command="{Binding ExitCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding AddCurvesDispatchCommand}"/>
        <KeyBinding Gesture="Ctrl+M" Command="{Binding ManageCurvesDispatchCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Delete" Command="{Binding ClearAllCurvesDispatchCommand}"/>
        <KeyBinding Gesture="Ctrl+L" Command="{Binding AddEventLineCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+L" Command="{Binding ClearEventLinesDispatchCommand}"/>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding ToggleHoverTooltipsCommand}"/>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FormatCompactPaneCommand}"/>
        <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding ShowSettingsCommand}"/>
        <KeyBinding Gesture="Ctrl+R" Command="{Binding ToggleAnalysisPanelCommand}"/>
        <KeyBinding Gesture="Ctrl+I" Command="{Binding ToggleInlineMetricsCommand}"/>
    </Window.KeyBindings>

    <DockPanel>
        <!-- Menu Bar with X-Axis Parameter Selector -->
        <DockPanel DockPanel.Dock="Top">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="10,0,10,0">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{x:Static ac:BoolConverters.And}">
                        <Binding Path="IsProjectActive"/>
                        <Binding Path="IsGroupedMode" Converter="{StaticResource InverseBool}"/>
                    </MultiBinding>
                </StackPanel.IsVisible>
                <TextBlock Text="X-Axis Parameter:"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding AvailableXColumns}"
                         SelectedItem="{Binding SelectedXColumn}"
                         MinWidth="200"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="_New Project"
                              Command="{Binding NewProjectCommand}"
                              InputGesture="Ctrl+N"/>
                    <Separator/>
                    <MenuItem Header="Open _Project..."
                              Command="{Binding OpenProjectCommand}"
                              InputGesture="Ctrl+O"/>
                    <MenuItem Header="Open _Recent" Name="OpenRecentMenu"/>
                    <Separator/>
                    <MenuItem Header="_Save Project"
                              Command="{Binding SaveProjectCommand}"
                              InputGesture="Ctrl+S"/>
                    <MenuItem Header="Save Project _As..."
                              Command="{Binding SaveProjectAsCommand}"
                              InputGesture="Ctrl+Shift+S"/>
                    <Separator/>
                    <MenuItem Header="_Export Image..."
                              Command="{Binding ExportImageCommand}"
                              InputGesture="Ctrl+E"/>
                    <MenuItem Header="Export _Intersections..."
                              Command="{Binding ExportIntersectionsCommand}"
                              InputGesture="Ctrl+Shift+E"/>
                    <Separator/>
                    <MenuItem Header="E_xit"
                              Command="{Binding ExitCommand}"
                              InputGesture="Ctrl+Q"/>
                </MenuItem>

                <MenuItem Header="_Curves"
                          IsVisible="{Binding !IsGroupedMode}">
                    <MenuItem Header="_Add Curves..."
                              IsVisible="{Binding IsPanesMode}"
                              IsEnabled="False"
                              InputGesture="Ctrl+Shift+A"
                              ToolTip.ShowOnDisabled="True"
                              ToolTip.Tip="In Stacked mode, right-click the desired pane and choose &quot;Add Curves...&quot; to add curves to that pane."/>
                    <MenuItem Header="Add Co_mpact Curves..."
                              Command="{Binding AddCompactCurvesCommand}"
                              IsVisible="{Binding IsCompactMode}"
                              InputGesture="Ctrl+Shift+A"/>
                    <MenuItem Header="_Manage Curves..."
                              IsVisible="{Binding IsPanesMode}"
                              IsEnabled="False"
                              InputGesture="Ctrl+M"
                              ToolTip.ShowOnDisabled="True"
                              ToolTip.Tip="In Stacked mode, right-click the desired pane and choose &quot;Manage Curve&quot; to edit its curves."/>
                    <MenuItem Header="_Manage Curve..."
                              Command="{Binding ManageCompactCurvesCommand}"
                              IsVisible="{Binding IsCompactMode}"
                              InputGesture="Ctrl+M"
                              ToolTip.Tip="Edit color, line style, markers, or delete a compact-surface curve"/>
                    <Separator IsVisible="{Binding IsPanesMode}"/>
                    <MenuItem Header="Clear _All Curves"
                              Command="{Binding ClearAllCurvesDispatchCommand}"
                              IsVisible="{Binding IsPanesMode}"
                              InputGesture="Ctrl+Shift+Delete"/>
                    <MenuItem Header="Clear _All Curves"
                              Command="{Binding ClearAllCurvesDispatchCommand}"
                              IsVisible="{Binding IsCompactMode}"
                              InputGesture="Ctrl+Shift+Delete"/>
                </MenuItem>

                <MenuItem Header="_Event Lines"
                          IsVisible="{Binding IsPanesMode}">
                    <MenuItem Header="_Add Event Line"
                              Command="{Binding AddEventLineCommand}"
                              InputGesture="Ctrl+L"/>
                    <MenuItem Header="_Clear All Event Lines"
                              Command="{Binding ClearEventLinesDispatchCommand}"
                              InputGesture="Ctrl+Shift+L"/>
                </MenuItem>

                <!-- Statistics: the single home for per-curve descriptive statistics. The panel
                     toggle (Ctrl+R), the Stacked-only inline overlay, and the three config dialogs
                     (which X-ranges to compute over, which columns to show, tolerance bands) all
                     live here so they're not split across View + Curves. Shown only when stats are
                     available (Stacked / Compact); Grouped has no statistics. -->
                <MenuItem Header="_Statistics"
                          IsVisible="{Binding IsAnalysisAvailable}">
                    <MenuItem Header="Show Statistics _Panel"
                              Command="{Binding ToggleAnalysisPanelCommand}"
                              IsChecked="{Binding ShowAnalysisPanel}"
                              ToggleType="CheckBox"
                              InputGesture="Ctrl+R"
                              ToolTip.Tip="Show or hide the per-curve statistics panel"/>
                    <!-- Inline overlay is Stacked-only (drawn in each pane corner). Stays visible
                         whenever statistics are available so the menu layout doesn't shift between
                         modes, but disables itself in Compact (CanExecute is gated on IsPanesMode). -->
                    <MenuItem Header="_Inline Overlay"
                              Command="{Binding ToggleInlineMetricsCommand}"
                              IsChecked="{Binding ShowInlineMetrics}"
                              ToggleType="CheckBox"
                              InputGesture="Ctrl+I"
                              ToolTip.Tip="Draw the top statistics for each visible curve in the corner of its pane (Stacked mode only)"/>
                    <Separator/>
                    <MenuItem Header="_Segments..."
                              Command="{Binding ManageAnalysisSegmentsCommand}"
                              ToolTip.Tip="Choose the time range statistics are computed over — rename, delete, or activate a segment (Shift+drag the plot to create one)"/>
                    <MenuItem Header="_Columns..."
                              Command="{Binding ManageMetricsCommand}"
                              ToolTip.Tip="Choose which statistics appear as columns in the panel, and in what order"/>
                    <MenuItem Header="_Tolerance Band..."
                              Command="{Binding ManageToleranceBandCommand}"
                              ToolTip.Tip="Define a ± tolerance / spec-limit band on a curve and report % in-band, crossings, exceedance, and max excursion"/>
                </MenuItem>

                <MenuItem Header="_Tools">
                    <MenuItem Header="Show Hover _Tooltips"
                              Command="{Binding ToggleHoverTooltipsCommand}"
                              InputGesture="Ctrl+T"
                              IsChecked="{Binding HoverTooltipsEnabled}"
                              ToggleType="CheckBox"/>
                    <MenuItem Header="_Format Pane..."
                              Command="{Binding FormatCompactPaneCommand}"
                              IsVisible="{Binding IsCompactMode}"
                              InputGesture="Ctrl+F"
                              ToolTip.Tip="Configure gridlines, X-axis, and background for the Compact Plot Surface"/>
                    <MenuItem Header="Configure _Inputs..."
                              Command="{Binding ConfigureGroupedInputsCommand}"
                              IsVisible="{Binding IsGroupedMode}"
                              ToolTip.Tip="Pick which columns are grouping inputs and which X/Y columns to plot"/>
                    <Separator/>
                    <MenuItem Header="_Settings..."
                              Command="{Binding ShowSettingsCommand}"
                              InputGesture="Ctrl+,"/>
                </MenuItem>

                <MenuItem Header="_Help">
                    <MenuItem Header="_User Guide"
                              x:Name="UserGuideMenuItem"
                              InputGesture="F1"/>
                    <MenuItem Header="_What's New"
                              x:Name="WhatsNewMenuItem"
                              InputGesture="Shift+F1"/>
                    <Separator/>
                    <MenuItem Header="Open _Log Folder"
                              x:Name="OpenLogFolderMenuItem"/>
                    <MenuItem Header="Set as _Default for .dpx Files"
                              Command="{Binding RegisterFileAssociationCommand}"
                              IsVisible="{Binding IsFileAssociationSupported}"
                              ToolTip.Tip="Register DatPlotX as the handler for .dpx project files so double-clicking one opens it here (current user only)."/>
                    <Separator/>
                    <MenuItem Header="_About DatPlotX"
                              x:Name="AboutMenuItem"/>
                </MenuItem>
            </Menu>
        </DockPanel>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#F0F0F0"
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Padding="10,2">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"/>

                <TextBlock Text="{Binding MousePositionText}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontFamily="Consolas"/>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid x:Name="MainContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="70*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30*" MinHeight="0"/>
            </Grid.RowDefinitions>

            <!-- Plot surface — full width. The Analysis Results panel now lives in the
                 bottom pane beside Source Data (split horizontally; see BottomPaneBorder). -->
            <Grid Grid.Row="0" ClipToBounds="True">

                <!-- Multi-Pane Plot Area (Vertically Stacked) — visible in Panes mode -->
                <ItemsControl Grid.Column="0"
                             x:Name="panesContainer"
                             ItemsSource="{Binding Panes}"
                             Margin="10,0,10,0">
                    <ItemsControl.IsVisible>
                        <MultiBinding Converter="{x:Static ac:BoolConverters.And}">
                            <Binding Path="IsProjectActive"/>
                            <Binding Path="IsPanesMode"/>
                        </MultiBinding>
                    </ItemsControl.IsVisible>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:PlotPaneControl MinHeight="150"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Compact Plot Surface — visible in Compact mode -->
                <ContentControl Grid.Column="0"
                                x:Name="compactSurfaceHost"
                                Margin="10,0,10,0">
                    <ContentControl.IsVisible>
                        <MultiBinding Converter="{x:Static ac:BoolConverters.And}">
                            <Binding Path="IsProjectActive"/>
                            <Binding Path="IsCompactMode"/>
                        </MultiBinding>
                    </ContentControl.IsVisible>
                    <views:CompactPlotControl x:Name="compactSurface"
                                              DataContext="{Binding CompactPlot}"/>
                </ContentControl>

                <!-- Grouped Parameter Plot — visible in Grouped mode -->
                <ContentControl Grid.Column="0"
                                x:Name="groupedSurfaceHost"
                                Margin="10,0,10,0">
                    <ContentControl.IsVisible>
                        <MultiBinding Converter="{x:Static ac:BoolConverters.And}">
                            <Binding Path="IsProjectActive"/>
                            <Binding Path="IsGroupedMode"/>
                        </MultiBinding>
                    </ContentControl.IsVisible>
                    <views:GroupedPlotControl x:Name="groupedSurface"
                                              DataContext="{Binding GroupedPlot}"/>
                </ContentControl>
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Row="1"
                          Height="3"
                          HorizontalAlignment="Stretch"
                          Background="#E0E0E0"
                          ResizeDirection="Rows"
                          Cursor="SizeNorthSouth"
                          x:Name="BottomPaneSplitter"
                          IsVisible="{Binding IsProjectActive}"/>

            <!-- Collapse/Expand Button -->
            <Button Grid.Row="1"
                    x:Name="ToggleBottomPaneButton"
                    Content="&#x25BC;"
                    Width="30"
                    Height="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#E0E0E0"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1"
                    FontSize="10"
                    ToolTip.Tip="Click to hide/show Source Data"
                    Cursor="Hand"
                    ZIndex="1"
                    IsVisible="{Binding IsProjectActive}"/>

            <!-- Bottom pane: Source Data (left) | Analysis Results (right), split
                 horizontally with a draggable splitter. The Analysis column collapses to 0
                 (and its splitter hides) when analysis is unavailable or toggled off — then
                 Source Data fills the whole pane, exactly like the original layout. -->
            <Border Grid.Row="2"
                    x:Name="BottomPaneBorder"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    Margin="10,0,10,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Auto = size to the Analysis panel's natural content width so all
                             stat columns are visible by default; collapses to 0 when off.
                             The panel's own MaxWidth caps it on very wide screens. -->
                        <ColumnDefinition Width="{Binding IsAnalysisPanelVisible, Converter={StaticResource BoolToGridLength}, ConverterParameter=Auto}"/>
                    </Grid.ColumnDefinitions>

                    <!-- Source Data (left) -->
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Source Data"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="5"
                                   Padding="5"
                                   Background="#F8F8F8"/>

                        <DataGrid x:Name="SourceDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  Margin="5"/>
                    </DockPanel>

                    <!-- Splitter between Source Data and Analysis -->
                    <GridSplitter Grid.Column="1"
                                  Width="3"
                                  VerticalAlignment="Stretch"
                                  Background="#E0E0E0"
                                  ResizeDirection="Columns"
                                  Cursor="SizeWestEast"
                                  IsVisible="{Binding IsAnalysisPanelVisible}"/>

                    <!-- Analysis Results (right). Width driven by IsAnalysisPanelVisible;
                         collapses to 0 when off. ClipToBounds stops bleed past the edge. -->
                    <Border Grid.Column="2"
                            MinWidth="0"
                            MaxWidth="1200"
                            ClipToBounds="True"
                            Margin="5,0,0,0"
                            IsVisible="{Binding IsAnalysisPanelVisible}">
                        <views:AnalysisPanel DataContext="{Binding AnalysisPanel}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Startup Welcome View — shown when no project is active -->
            <Grid Grid.Row="0"
                  Grid.RowSpan="3"
                  x:Name="WelcomeView"
                  Background="White"
                  IsVisible="{Binding IsProjectActive, Converter={StaticResource InverseBool}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="40">
                    <TextBlock Text="DatPlotX"
                               FontSize="48"
                               FontWeight="Light"
                               Foreground="#7F7F7F"
                               HorizontalAlignment="Center"/>
                    <Grid HorizontalAlignment="Center"
                          ColumnDefinitions="Auto,40,Auto"
                          RowDefinitions="Auto,16,Auto">
                        <Button Grid.Row="0" Grid.Column="0"
                                Command="{Binding NewProjectCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6,4"
                                Cursor="Hand"
                                HorizontalAlignment="Right">
                            <TextBlock Text="New Project"
                                       FontSize="18"
                                       Foreground="#1B1B1B"/>
                        </Button>
                        <StackPanel Grid.Row="0" Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center">
                            <Border Background="#E5E5E5"
                                    BorderBrush="#BFBFBF"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,2">
                                <TextBlock Text="Ctrl"
                                           FontSize="13"
                                           Foreground="#3F3F3F"/>
                            </Border>
                            <Border Background="#E5E5E5"
                                    BorderBrush="#BFBFBF"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,2">
                                <TextBlock Text="N"
                                           FontSize="13"
                                           Foreground="#3F3F3F"/>
                            </Border>
                        </StackPanel>

                        <Button Grid.Row="2" Grid.Column="0"
                                Command="{Binding OpenProjectCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6,4"
                                Cursor="Hand"
                                HorizontalAlignment="Right">
                            <TextBlock Text="Open Project..."
                                       FontSize="18"
                                       Foreground="#1B1B1B"/>
                        </Button>
                        <StackPanel Grid.Row="2" Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center">
                            <Border Background="#E5E5E5"
                                    BorderBrush="#BFBFBF"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,2">
                                <TextBlock Text="Ctrl"
                                           FontSize="13"
                                           Foreground="#3F3F3F"/>
                            </Border>
                            <Border Background="#E5E5E5"
                                    BorderBrush="#BFBFBF"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,2">
                                <TextBlock Text="O"
                                           FontSize="13"
                                           Foreground="#3F3F3F"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
