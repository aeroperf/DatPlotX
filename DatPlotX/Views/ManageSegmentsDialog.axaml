<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DatPlotX.Views"
        xmlns:vm="clr-namespace:DatPlotX.ViewModels"
        x:Class="DatPlotX.Views.ManageSegmentsDialog"
        x:DataType="vm:ManageSegmentsDialogViewModel"
        x:CompileBindings="True"
        Title="Statistics Segments"
        Height="440" Width="640"
        Classes="dpx"
        Background="{StaticResource DpxBg}"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header band -->
        <StackPanel Grid.Row="0" Margin="20,16,20,12" Spacing="2">
            <TextBlock Classes="dpx-h1" Text="Statistics segments" Margin="0"/>
            <TextBlock Classes="dpx-subtitle"
                       Text="Choose the time range statistics are computed over. The selected segment becomes active; rename in place, or mark Manual segments for removal."
                       Margin="0"/>
        </StackPanel>

        <!-- Grid -->
        <Border Grid.Row="1" Margin="20,0,20,12"
                Background="{StaticResource DpxSurface}"
                BorderBrush="{StaticResource DpxBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <DataGrid ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="False"
                      CanUserResizeColumns="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="Transparent"
                      BorderThickness="0">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name, Mode=TwoWay}"
                                        Width="200"/>

                    <DataGridTextColumn Header="X-range"
                                        Binding="{Binding RangeDisplay}"
                                        IsReadOnly="True"
                                        Width="180"/>

                    <DataGridTextColumn Header="Source"
                                        Binding="{Binding SourceDisplay}"
                                        IsReadOnly="True"
                                        Width="120"/>

                    <DataGridTemplateColumn Header="" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:SegmentRowViewModel">
                                <Button Classes="dpx ghost"
                                        Margin="6,3"
                                        Height="26" MinHeight="0" Padding="10,0"
                                        IsVisible="{Binding CanDelete}"
                                        Command="{Binding MarkForRemovalCommand}"
                                        Content="{Binding IsMarkedForRemoval,
                                                 Converter={x:Static views:ManageSegmentsDialog.RemoveButtonConverter}}">
                                    <ToolTip.Tip>Mark for removal</ToolTip.Tip>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Classes="dpx-footer">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Button Grid.Column="1" Classes="dpx ghost" Content="Cancel"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2" Classes="dpx primary" Content="Apply"
                        Click="Apply_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
